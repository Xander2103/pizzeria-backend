<h1>Gegevens invullen</h1>

{% if error is not empty %}
  <p style="color:red;"><strong>{{ error }}</strong></p>
{% endif %}

<form method="post" action="?page=checkout_guest">
  <div>
    <label>Familienaam</label><br>
    <input type="text" name="last_name" value="{{ old.last_name|default('')|e }}" required>
  </div>

  <div>
    <label>Voornaam</label><br>
    <input type="text" name="first_name" value="{{ old.first_name|default('')|e }}" required>
  </div>

  <div>
    <label>Straat</label><br>
    <input type="text" name="street" value="{{ old.street|default('')|e }}" required>
  </div>

  <div>
    <label>Huisnummer</label><br>
    <input type="text" name="house_number" value="{{ old.house_number|default('')|e }}" required>
  </div>

  <div>
    <label>Postcode</label><br>
    <input type="text" name="postal_code" value="{{ old.postal_code|default('')|e }}" required>
  </div>

  <div>
    <label>Gemeente</label><br>
    <input type="text" name="city" value="{{ old.city|default('')|e }}" required>
  </div>

  <div>
    <label>Telefoonnummer</label><br>
    <input type="text" name="phone_number" value="{{ old.phone_number|default('')|e }}" required>
  </div>

  <div style="margin-top:10px;">
    <label>
      <input
        type="checkbox"
        id="create_account"
        name="create_account"
        value="1"
        {% if old.create_account|default('0') == '1' %}checked{% endif %}
      >
      Maak meteen een account aan
    </label>
  </div>

  <div id="account_fields"; margin-top:10px;">
    <div>
      <label>E-mail</label><br>
      <input type="email" name="new_email" value="{{ old.new_email|default('')|e }}">
    </div>

    <div>
      <label>Wachtwoord</label><br>
      <input type="password" name="new_password">
    </div>
  </div>

  <button type="submit">Verder</button>
</form>

<p><a href="?page=checkout">Terug</a></p>

